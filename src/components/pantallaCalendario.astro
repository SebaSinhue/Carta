<section
  id="calendar-screen"
  class="fixed inset-0 z-20 translate-x-full overflow-hidden bg-[#f7efe7] bg-cover bg-center px-4 md:px-10 transition-transform duration-700 ease-in-out"
  style="background-image: url('/img/papelArrugado.jpg');"
>
  <!-- CONTENEDOR DE FOTOS/VIDEOS FLOTANTES (Fondo) -->
  <div id="floating-media-container" class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- 
      INSTRUCCIONES: 
      Pon aquí las rutas de tus fotos y videos. 
      Tienen la clase 'opacity-0' para estar ocultos al inicio. 
      Puedes mezclar formas (rounded-xl, rounded-full) y bordes.
    -->
    <img src="/img/ali1.jpeg" class="floating-media absolute opacity-0 transition-opacity duration-1000 ease-in-out w-40 h-40 md:w-56 md:h-56 object-cover rounded-xl shadow-xl border-[6px] border-white" />
    <img src="/img/ali2.jpeg" class="floating-media absolute opacity-0 transition-opacity duration-1000 ease-in-out w-36 h-36 md:w-48 md:h-48 object-cover rounded-3xl shadow-xl border-4 border-white" />
    <img src="/img/ali3.jpeg" class="floating-media absolute opacity-0 transition-opacity duration-1000 ease-in-out w-44 h-44 md:w-60 md:h-60 object-cover rounded-full shadow-xl border-4 border-[#8b5e3c]/30" />
    
    <!-- Para videos, es MUY importante dejar 'muted loop playsinline' para que el navegador permita reproducirlos automáticamente -->
    <video src="/vid/aliVid1.mp4" class="floating-media absolute opacity-0 transition-opacity duration-1000 ease-in-out w-40 h-48 md:w-56 md:h-64 object-cover rounded-lg shadow-xl border-[6px] border-white" muted loop playsinline></video>
    <video src="/vid/aliVid2.mp4" class="floating-media absolute opacity-0 transition-opacity duration-1000 ease-in-out w-36 h-36 md:w-52 md:h-52 object-cover rounded-full shadow-xl border-4 border-white" muted loop playsinline></video>
  </div>

  <div class="flex min-h-screen flex-col items-center justify-center text-center relative z-10 py-6">
    <!-- Tarjeta principal (Más compacta: py-8, max-w-[750px]) -->
    <div class="letter-card relative w-full max-w-[750px] rounded-[2.5rem] border border-[#8b5e3c]/30 bg-[#fff7e8]/95 px-6 py-8 shadow-2xl">
      
      <!-- Encabezado y Título -->
      <div class="mb-1 text-3xl text-[#a51f32]">❤️</div>
      <h2 class="mb-4 flex flex-col items-center justify-center">
        <span class="font-romantic text-3xl md:text-4xl italic text-[#a51f32]">Y desde este dia</span>
        <span class="mt-1 text-4xl md:text-5xl font-normal tracking-[0.1em] text-[#a51f32]">ESTAMOS JUNTOS</span>
      </h2>

      <!-- Subtítulo con hilo decorativo -->
      <div class="mx-auto mb-6 flex w-full max-w-[600px] items-center justify-center gap-3 text-[#8b5e3c]">
        <p class="w-2/5 text-right font-romantic text-sm md:text-base italic leading-relaxed">
          Cada palabra es un<br />hilo que teje la
        </p>
        
        <div class="flex flex-1 items-center justify-center gap-2">
          <div class="h-[1px] w-full bg-[#8b5e3c]/50"></div>
          <svg class="h-6 w-6 text-[#8b5e3c]/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          <div class="h-[1px] w-full bg-[#8b5e3c]/50"></div>
        </div>

        <p class="w-2/5 text-left font-romantic text-sm md:text-base italic leading-relaxed">
          historia que quiero<br />construir contigo.
        </p>
      </div>

      <!-- CONTENEDOR DEL CALENDARIO -->
      <div class="calendar-deploy mx-auto w-full max-w-[550px] drop-shadow-xl">
        
        <!-- EFECTO DE ONDAS (Más compacto: p-6) -->
        <div class="scalloped-edge px-6 py-8 text-white">
          <h3 class="mb-4 font-romantic text-4xl italic drop-shadow-md">Mayo</h3>
          
          <!-- Cuadrícula del mes (text-lg en lugar de xl, py-2 en lugar de py-4) -->
          <div class="flex flex-col text-lg font-medium tracking-wide">
            
            <div class="grid grid-cols-7 border-b border-white/40 pb-2">
              <div class="opacity-0">26</div><div class="opacity-0">27</div><div class="opacity-0">28</div><div class="opacity-0">29</div><div class="opacity-0">30</div>
              <div>1</div><div>2</div>
            </div>
            
            <div class="grid grid-cols-7 border-b border-white/40 py-2">
              <div>3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div>
            </div>
            
            <div class="grid grid-cols-7 border-b border-white/40 py-2">
              <div>10</div><div>11</div><div>12</div><div>13</div><div>14</div>
              
              <div class="relative flex items-center justify-center">
                <span class="relative z-10 font-bold text-white drop-shadow-md">15</span>
                <svg class="heartbeat-icon absolute h-12 w-12 text-[#cc2738] drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                </svg>
              </div>
              
              <div>16</div>
            </div>
            
            <div class="grid grid-cols-7 border-b border-white/40 py-2">
              <div>17</div><div>18</div><div>19</div><div>20</div><div>21</div><div>22</div><div>23</div>
            </div>

            <div class="grid grid-cols-7 pt-2">
              <div>24</div><div>25</div><div>26</div><div>27</div><div>28</div><div>29</div><div>30</div>
            </div>
            <div class="grid grid-cols-7 pb-1">
              <div>31</div><div></div><div></div><div></div><div></div><div></div><div></div>
            </div>

          </div>
        </div>
      </div>

      <!-- Botones (Más pequeños) -->
      <div class="mt-8 flex justify-center gap-6">
        <button id="btn-back-calendar" class="rounded-full border border-[#8f2636] px-8 py-2 font-romantic text-base italic text-[#8f2636] active:scale-95">
          BACK
        </button>
        <button id="btn-next-calendar" class="rounded-full bg-[#b22234] px-8 py-2 font-romantic text-base italic text-white shadow-md active:scale-95">
          NEXT
        </button>
      </div>

    </div>
  </div>
</section>

<style>
  /* --- EFECTO DE ONDAS --- */
  .scalloped-edge {
    position: relative;
    background-color: #89b2f5;
    z-index: 1; 
  }

  .scalloped-edge::before {
    content: "";
    position: absolute;
    top: -12px; left: -12px; right: -12px; bottom: -12px;
    background-image: radial-gradient(circle, #89b2f5 50%, transparent 53%);
    background-size: 24px 24px; /* Ondas un poco más pequeñas */
    background-position: center;
    background-repeat: round; 
    z-index: -1; 
  }

  /* Animación del calendario */
  .calendar-deploy {
    opacity: 0;
    transform: translateY(80px);
  }

  #calendar-screen.open .calendar-deploy {
    animation: slideUpCalendar 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.4s;
  }

  @keyframes slideUpCalendar {
    from { opacity: 0; transform: translateY(80px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Latido del corazón */
  .heartbeat-icon {
    animation: heartbeat 1.5s infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    15% { transform: scale(1.15); }
    30% { transform: scale(1); }
    45% { transform: scale(1.15); }
    60% { transform: scale(1); }
  }
</style>

<script>
  const mediaItems = document.querySelectorAll('.floating-media') as NodeListOf<HTMLElement>;

  function showRandomMedia() {
    if (mediaItems.length === 0) return;

    const randomIndex = Math.floor(Math.random() * mediaItems.length);
    const item = mediaItems[randomIndex];

    if (item.classList.contains('opacity-0')) {
      if (item.tagName.toLowerCase() === 'video') {
        (item as HTMLVideoElement).play().catch(() => {});
      }

      const randomX = Math.floor(Math.random() * 70) + 10;
      const randomY = Math.floor(Math.random() * 70) + 10;
      const randomRotation = Math.floor(Math.random() * 50) - 25;

      item.style.left = `${randomX}%`;
      item.style.top = `${randomY}%`;
      item.style.transform = `rotate(${randomRotation}deg)`;

      item.classList.remove('opacity-0');
      item.classList.add('opacity-100');

      setTimeout(() => {
        item.classList.remove('opacity-100');
        item.classList.add('opacity-0');

        setTimeout(() => {
          if (item.tagName.toLowerCase() === 'video') {
            (item as HTMLVideoElement).pause();
          }
        }, 500);
      }, 2000);
    }
  }

  setInterval(showRandomMedia, 2500);

  const calendarScreen = document.getElementById("calendar-screen");
  const musicScreen = document.getElementById("music-screen");

  const btnNextCalendar = document.getElementById("btn-next-calendar");
  const btnBackMusic = document.getElementById("btn-back-music");

  btnNextCalendar?.addEventListener("click", () => {
    musicScreen?.classList.remove("translate-x-full");
    calendarScreen?.classList.add("-translate-x-full");
  });

  btnBackMusic?.addEventListener("click", () => {
    musicScreen?.classList.add("translate-x-full");
    calendarScreen?.classList.remove("-translate-x-full");
  });
</script>