<section
  id="letter-screen"
  class="fixed inset-0 z-20 translate-x-full overflow-hidden bg-[#f7efe7] bg-cover bg-center px-10 transition-transform duration-700 ease-in-out"
  style="background-image: url('/img/papelArrugado.jpg');"
>
  <div class="flex min-h-screen flex-col items-center justify-center text-center">
    <div class="letter-card relative w-full max-w-[900px] rounded-[3rem] border border-[#8b5e3c]/30 bg-[#fff7e8]/90 px-10 py-10 shadow-2xl">
      <div class="mb-2 text-4xl text-[#a51f32]">💖</div>

      <h2 class="mb-1 font-romantic text-5xl italic text-[#a51f32]">
        Para ti
      </h2>

      <p class="mb-4 text-sm tracking-[0.25em] text-[#a51f32]/80">
        UNA CARTA HECHA CON CARIÑO
      </p>

      <div class="relative mx-auto mt-32 h-[500px] w-[800px]">
        <div class="envelope-wrap absolute bottom-0 left-1/2 h-[350px] w-[750px] -translate-x-1/2 [perspective:1000px]">
          
          <div class="paper absolute inset-x-0 bottom-[60px] z-10 mx-auto h-[300px] w-[650px] rounded-xl bg-white px-10 py-10 text-left shadow-md">
            <p class="font-romantic text-[18px] italic leading-7 text-[#8f2636]">
              Aquí escribiré mi carta... Ahora tienes mucho más espacio a lo ancho y a lo alto. Si tu texto llega a ser extremadamente largo, no te preocupes, la propiedad de scroll se activará automáticamente permitiendo leer todo sin romper la estructura del sobre.
            </p>
          </div>

          <div class="absolute bottom-0 left-0 z-0 h-[320px] w-[750px] rounded-b-xl bg-[#eee2d9] shadow-lg"></div>

          <div class="envelope-flap absolute left-0 top-0 z-30"></div>

          <div class="envelope-front absolute bottom-0 left-0 z-20 h-[320px] w-[750px] rounded-b-xl"></div>
        </div>
      </div>

      <div class="mt-8 flex justify-center gap-6">
        <button
          id="btn-back-flowers"
          class="rounded-full border border-[#8f2636] px-10 py-3 font-romantic italic text-[#8f2636] active:scale-95 text-lg"
        >
          BACK
        </button>

        <button id="btn-next-letter" class="rounded-full bg-[#b22234] px-7 py-2 font-romantic italic text-white shadow-md active:scale-95">
          NEXT
        </button>

      </div>
    </div>
  </div>
</section>

<style>
  .letter-card {
    animation: cardIn 0.7s ease forwards;
  }

  .paper {
    opacity: 0;
    transform: translateY(150px);
  }

  #letter-screen.open .paper {
    animation: paperOut 1s ease forwards;
    animation-delay: 1.1s;
  }

  .envelope-flap {
    width: 0;
    height: 0;
    border-left: 375px solid transparent;
    border-right: 375px solid transparent;
    border-top: 250px solid #f8f1ec;
    transform-origin: top center;
  }

  #letter-screen.open .envelope-flap {
    animation: openFlap 0.9s ease forwards;
    animation-delay: 0.4s;
  }

  .envelope-front {
    background:
      linear-gradient(145deg, transparent 49.5%, #e6d8cf 50%),
      linear-gradient(215deg, transparent 49.5%, #ded0c8 50%),
      #f1e7df;
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(25px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes openFlap {
    from {
      transform: rotateX(0deg);
      z-index: 30;
    }
    to {
      transform: rotateX(180deg);
      z-index: 5;
    }
  }

  @keyframes paperOut {
    from {
      opacity: 0;
      transform: translateY(150px);
    }
    to {
      opacity: 1;
      transform: translateY(-200px); 
    }
  }
</style>

<script>
  const letterScreen = document.getElementById("letter-screen");
  const calendarScreen = document.getElementById("calendar-screen");

  const btnNextLetter = document.getElementById("btn-next-letter");
  const btnBackCalendar = document.getElementById("btn-back-calendar");

  btnNextLetter?.addEventListener("click", () => {
    calendarScreen?.classList.remove("translate-x-full");
    letterScreen?.classList.add("-translate-x-full");

    setTimeout(() => {
      calendarScreen?.classList.add("open");
    }, 750);
  });

  btnBackCalendar?.addEventListener("click", () => {
    calendarScreen?.classList.add("translate-x-full");
    calendarScreen?.classList.remove("open");
    letterScreen?.classList.remove("-translate-x-full");

    setTimeout(() => {
      letterScreen?.classList.add("open");
    }, 750);
  });
</script>