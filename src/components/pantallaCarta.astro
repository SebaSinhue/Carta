<section
  id="letter-screen"
  class="fixed inset-0 z-20 translate-x-full overflow-x-hidden overflow-y-auto bg-[#f7efe7] bg-cover bg-center px-4 md:px-10 transition-transform duration-700 ease-in-out"
  style="background-image: url('/Carta/img/papelArrugado.jpg');"
>
  <div class="flex min-h-screen flex-col items-center justify-center text-center py-10">
    
    <!-- TARJETA PRINCIPAL: Se adapta en móviles (px-4) y escritorio (px-10) -->
    <div class="letter-card relative w-full max-w-[900px] rounded-[2rem] md:rounded-[3rem] border border-[#8b5e3c]/30 bg-[#fff7e8]/90 px-4 md:px-10 py-8 md:py-10 shadow-2xl">
      <div class="mb-2 text-3xl md:text-4xl text-[#a51f32]">💖</div>

      <h2 class="mb-1 font-romantic text-4xl md:text-5xl italic text-[#a51f32]">
        Para ti
      </h2>

      <p class="mb-6 md:mb-4 text-xs md:text-sm tracking-[0.25em] text-[#a51f32]/80">
        UNA CARTA HECHA CON CARIÑO
      </p>

      <!-- CONTENEDOR DEL SOBRE: Tamaño dinámico según la pantalla -->
      <div class="relative mx-auto mt-6 md:mt-32 h-[300px] md:h-[500px] w-full max-w-[280px] md:max-w-[800px]">
        <div class="envelope-wrap absolute bottom-0 left-1/2 h-[200px] md:h-[350px] w-[280px] md:w-[750px] -translate-x-1/2 [perspective:1000px]">
          
          <!-- PAPEL: Más pequeño en celular, grande en PC. Con scroll interno -->
          <div class="paper absolute inset-x-0 bottom-[40px] md:bottom-[60px] z-10 mx-auto h-[220px] md:h-[300px] w-[250px] md:w-[650px] overflow-y-auto rounded-xl bg-white px-5 py-6 md:px-10 md:py-10 text-left shadow-md">
            <p class="font-romantic text-[16px] md:text-[18px] italic leading-6 md:leading-7 text-[#8f2636]">
              Hola Aline bueno mejor dicho "Hola amor de mi vida" esta carta te la escribo ya que eres una persona que significa demasiado para mi, eres el motor de mi vida y eres mi persona favorita. Desde el momento en que te comence a conocer mas supe que eras la persona con la que queria compartir mi vida de aqui en adelante, te convertiste en parte de mi rutina y tambien en mi futuro. Quiero que sepas que siempre estare para ti en los momentos buenos pero sobretodo en los momentos malos, en los peores y en los catastroficos. 
              Estoy muy orgulloso de la persona que eres ya que eres super inteligente, super creativa, super espontanea y sobre todo eres una lindura de persona, siempre y por siempre me preguntare que bueno hice para merecer una mujer tan espectacular como lo eres tu. Quiero que sepas que mi amor, mi cariño y mi aprecio es el mas leal y puro del universo, eres una persona con la que mis emociones y reacciones son naturales porque simplemente me siento muy tranquilo a tu lado.
              En el poquito tiempo que llevamos saliendo y siendo pareja me di cuenta que eres tú la persona ideal con la que quiero vivir el resto de mi vida, se que siempre estoy recordandote lo mucho que te amo pero esta carta es para afirmarte todavia mas que puedesn confiar en mi ya que el amor que siento por ti es inmeso.
              Por ultimo y no menos importante gracias por haber llegado a mi vida, gracias por darle sentido a las canciones nuevamente, gracias por darme de tu valioso tiempo, gracias por regalarme tus abrazos, tus risas y tus sonrisas, gracias por haberme permitido entrar en tu rutina y sobre todo gracias por ser mi novia. Con amor Sebastian 💖

              PD. Esta carta la hice con mucho cariño aunque sea una pagina web y me gusta mas ya que el papel se puede llegar a desgastar pero esto es eterno como el amor que siento por ti 
              PD 2. Estas muy bonita
              PD 3. Te adoro con toda mi vida 
            </p>
          </div>

          <!-- Parte trasera del sobre -->
          <div class="absolute bottom-0 left-0 z-0 h-[170px] md:h-[320px] w-[280px] md:w-[750px] rounded-b-xl bg-[#eee2d9] shadow-lg"></div>

          <!-- Solapa del sobre (Controlada en CSS) -->
          <div class="envelope-flap absolute left-0 top-0 z-30"></div>

          <!-- Frente del sobre -->
          <div class="envelope-front absolute bottom-0 left-0 z-20 h-[170px] md:h-[320px] w-[280px] md:w-[750px] rounded-b-xl"></div>
        </div>
      </div>

      <!-- BOTONES -->
      <div class="mt-4 md:mt-8 flex justify-center gap-4 md:gap-6">
        <button
          id="btn-back-flowers"
          class="rounded-full border border-[#8f2636] px-6 py-2 md:px-10 md:py-3 font-romantic text-base md:text-lg italic text-[#8f2636] active:scale-95"
        >
          BACK
        </button>

        <button 
          id="btn-next-letter" 
          class="rounded-full bg-[#b22234] px-6 py-2 md:px-10 md:py-3 font-romantic text-base md:text-lg italic text-white shadow-md active:scale-95"
        >
          NEXT
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .letter-card {
    animation: cardIn 0.7s ease forwards;
  }
  .envelope-flap {
    width: 0;
    height: 0;
    border-left: 140px solid transparent;
    border-right: 140px solid transparent;
    border-top: 110px solid #f8f1ec;
    transform-origin: top center;
  }

  /* El papel inicia más abajo en celulares */
  .paper {
    opacity: 0;
    transform: translateY(60px);
  }

  /* Llama a la animación corta para que no se salga de la pantalla */
  #letter-screen.open .paper {
    animation: paperOutMobile 1s ease forwards;
    animation-delay: 1.1s;
  }

  /* =========================================
     CONFIGURACIÓN ESCRITORIO (Tablets y PC)
     ========================================= */
  @media (min-width: 768px) {
    /* El sobre recupera sus 750px de ancho original */
    .envelope-flap {
      border-left: 375px solid transparent;
      border-right: 375px solid transparent;
      border-top: 250px solid #f8f1ec;
    }

    .paper {
      transform: translateY(150px);
    }

    #letter-screen.open .paper {
      animation: paperOutDesktop 1s ease forwards;
      animation-delay: 1.1s;
    }
  }

  /* Animación universal para abrir la solapa */
  #letter-screen.open .envelope-flap {
    animation: openFlap 0.9s ease forwards;
    animation-delay: 0.4s;
  }

  /* El gradiente del frente se mantiene intacto */
  .envelope-front {
    background:
      linear-gradient(145deg, transparent 49.5%, #e6d8cf 50%),
      linear-gradient(215deg, transparent 49.5%, #ded0c8 50%),
      #f1e7df;
  }

  /* --- ANIMACIONES --- */
  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translateY(25px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes openFlap {
    from {
      transform: rotateX(0deg);
      z-index: 30;
    }
    to {
      transform: rotateX(180deg);
      z-index: 5;
    }
  }

  /* Animación del papel subiendo para MÓVILES (Sube menos para no salirse) */
  @keyframes paperOutMobile {
    from {
      opacity: 0;
      transform: translateY(60px);
    }
    to {
      opacity: 1;
      transform: translateY(-90px); 
    }
  }

  /* Animación del papel subiendo para PC (Sube alto para lucirse) */
  @keyframes paperOutDesktop {
    from {
      opacity: 0;
      transform: translateY(150px);
    }
    to {
      opacity: 1;
      transform: translateY(-200px); 
    }
  }
</style>

<script>
  const letterScreen = document.getElementById("letter-screen");
  const calendarScreen = document.getElementById("calendar-screen");

  const btnNextLetter = document.getElementById("btn-next-letter");
  const btnBackCalendar = document.getElementById("btn-back-calendar");

  btnNextLetter?.addEventListener("click", () => {
    calendarScreen?.classList.remove("translate-x-full");
    letterScreen?.classList.add("-translate-x-full");

    setTimeout(() => {
      calendarScreen?.classList.add("open");
    }, 750);
  });

  btnBackCalendar?.addEventListener("click", () => {
    calendarScreen?.classList.add("translate-x-full");
    calendarScreen?.classList.remove("open");
    letterScreen?.classList.remove("-translate-x-full");

    setTimeout(() => {
      letterScreen?.classList.add("open");
    }, 750);
  });
</script>