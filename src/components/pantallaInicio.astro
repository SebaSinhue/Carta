<section
  id="start-screen"
  class="relative min-h-screen overflow-hidden bg-[#f7efe7] bg-cover bg-center flex items-center justify-center px-6 transition-transform duration-700 ease-in-out"
  style="background-image: url('/Carta/img/papelArrugado.jpg');"
>
  <div class="flex flex-col items-center text-center">
    <img
      src="/Carta/img/gatos.gif"
      alt="Gatitos"
      class="mb-8 block h-56 w-56 -translate-x-6 object-contain"
    />

    <h1 class="mb-4 text-5xl font-extrabold tracking-wide text-[#a51f32]">
      OYE AMOR!
    </h1>

    <p class="mb-10 text-sm font-semibold tracking-widest text-[#a51f32]/80">
      ABRE EL SIGUIENTE REGALITO
    </p>

    <div class="flex justify-center gap-8">
      <button
        id="btn-no"
        class="flex h-20 w-20 items-center justify-center rounded-full bg-[#b22234] text-5xl font-bold text-white shadow-xl transition active:scale-90"
      >
        ×
      </button>

      <button
        id="btn-yes"
        class="flex h-20 w-20 items-center justify-center rounded-full bg-[#b22234] text-5xl font-bold text-white shadow-xl transition active:scale-90"
      >
        ✓
      </button>
    </div>
  </div>
</section>

<script>
  const startScreen = document.getElementById("start-screen");
  const noScreen = document.getElementById("no-screen");
  const flowersScreen = document.getElementById("flowers-screen");

  const btnNo = document.getElementById("btn-no");
  const btnYes = document.getElementById("btn-yes");
  const btnBackStart = document.getElementById("btn-back-start");

  btnNo?.addEventListener("click", () => {
    noScreen?.classList.remove("-translate-x-full");
    startScreen?.classList.add("translate-x-full");
  });

  btnBackStart?.addEventListener("click", () => {
    noScreen?.classList.add("-translate-x-full");
    startScreen?.classList.remove("translate-x-full"); 
  });

  btnYes?.addEventListener("click", () => {
    flowersScreen?.classList.remove("translate-x-full");
    startScreen?.classList.add("-translate-x-full");
  });
</script>