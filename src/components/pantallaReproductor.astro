<section
  id="music-screen"
  class="fixed inset-0 z-20 translate-x-full overflow-x-hidden overflow-y-auto bg-[#f7efe7] bg-cover bg-center px-4 md:px-6 transition-transform duration-700 ease-in-out"
  style="background-image: url('/Carta/img/papelArrugado.jpg');"
>
  <div class="flex min-h-screen flex-col items-center justify-center text-center py-12">
    
    <div class="relative flex w-full max-w-[600px] flex-col rounded-[2rem] md:rounded-[3rem] bg-white/95 p-6 md:p-8 shadow-2xl ring-4 md:ring-8 ring-[#fff7e8]/80 ring-offset-4 ring-offset-[#a51f32]/10">
      
      <div class="mb-2 text-3xl md:text-4xl">🎧</div>
      
      <h2 class="mb-2 font-romantic text-4xl md:text-5xl italic text-[#a51f32]">
        Las canciones
      </h2>
      
      <p class="mb-6 text-xs md:text-lg font-semibold tracking-[0.25em] text-[#8b5e3c]/70 uppercase">
        que nos identifican
      </p>

      <div class="relative w-full flex items-center justify-center py-2">
        
        <button id="btn-prev-slide" class="absolute -left-2 md:-left-6 z-10 flex h-10 w-10 md:h-12 md:w-12 items-center justify-center rounded-full bg-white text-[#a51f32] shadow-lg border border-[#dfd0c6] transition-transform active:scale-90">
          <svg class="h-5 w-5 md:h-6 md:w-6 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
        </button>

        <div id="music-carousel" class="flex w-full overflow-x-auto snap-x snap-mandatory scroll-smooth hide-scrollbar gap-6 px-1">
          
          <div class="w-full flex-shrink-0 snap-center drop-shadow-md">
            <iframe data-testid="embed-iframe" style="border-radius:16px; border:none;" src="https://open.spotify.com/embed/track/6d3q0F9VNtdxQUTVlRcet6?utm_source=generator" width="100%" height="352" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
          </div>

          <div class="w-full flex-shrink-0 snap-center drop-shadow-md">
            <iframe data-testid="embed-iframe" style="border-radius:16px; border:none;" src="https://open.spotify.com/embed/track/7585wxMp2e3IhBq3tJAXgw?utm_source=generator" width="100%" height="352" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
          </div>

          <div class="w-full flex-shrink-0 snap-center drop-shadow-md">
            <iframe data-testid="embed-iframe" style="border-radius:16px; border:none;" src="https://open.spotify.com/embed/track/7mB696swDD8zMfnKyLqc6S?utm_source=generator" width="100%" height="352" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
          </div>

          <div class="w-full flex-shrink-0 snap-center drop-shadow-md">
            <iframe data-testid="embed-iframe" style="border-radius:16px; border:none;" src="https://open.spotify.com/embed/track/40skUFI0ICkDoRLbJNUT9O?utm_source=generator" width="100%" height="352" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
          </div>

          <div class="w-full flex-shrink-0 snap-center drop-shadow-md">
            <iframe data-testid="embed-iframe" style="border-radius:16px; border:none;" src="https://open.spotify.com/embed/track/6xP8vlX3SozwZTNDIrpUpG?utm_source=generator" width="100%" height="352" allowfullscreen allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
          </div>

        </div>

        <button id="btn-next-slide" class="absolute -right-2 md:-right-6 z-10 flex h-10 w-10 md:h-12 md:w-12 items-center justify-center rounded-full bg-[#a51f32] text-white shadow-lg border border-[#a51f32] transition-transform active:scale-90">
          <svg class="h-5 w-5 md:h-6 md:w-6 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
        </button>

      </div>

      <div class="mt-8 flex justify-center gap-4">
        <button id="btn-back-music" class="rounded-full border-2 border-[#8f2636] px-6 md:px-12 py-2 md:py-3 font-romantic text-base md:text-lg italic text-[#8f2636] transition hover:bg-[#8f2636] hover:text-white active:scale-95">
          BACK
        </button>

        <button id="btn-home-music" class="rounded-full bg-[#b22234] px-6 md:px-10 py-2 md:py-3 font-romantic text-base md:text-lg italic text-white shadow-md transition active:scale-95">
            INICIO
        </button>
      </div>

    </div>
  </div>
</section>

<style>
  /* Ocultar la barra de scroll por defecto para que parezca una galería limpia */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE y Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome, Safari y Opera */
  }
</style>

<script>
  // Pequeño script para que las flechas muevan la galería de canciones
  const carousel = document.getElementById('music-carousel') as HTMLElement | null;
  const btnPrevSlide = document.getElementById('btn-prev-slide') as HTMLButtonElement | null;
  const btnNextSlide = document.getElementById('btn-next-slide') as HTMLButtonElement | null;

  btnPrevSlide?.addEventListener('click', () => {
    if (carousel) {
      // Mueve el scroll hacia la izquierda el tamaño exacto de una canción
      carousel.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' });
    }
  });

  btnNextSlide?.addEventListener('click', () => {
    if (carousel) {
      // Mueve el scroll hacia la derecha el tamaño exacto de una canción
      carousel.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' });
    }
  });

  const startScreen = document.getElementById("start-screen");
  const musicScreen = document.getElementById("music-screen");
  const calendarScreen = document.getElementById("calendar-screen");
  const btnHomeMusic = document.getElementById("btn-home-music");

  btnHomeMusic?.addEventListener("click", () => {
    musicScreen?.classList.add("translate-x-full");
    musicScreen?.classList.remove("-translate-x-full");

    calendarScreen?.classList.add("translate-x-full");
    calendarScreen?.classList.remove("-translate-x-full");
    calendarScreen?.classList.remove("open");

    startScreen?.classList.remove("-translate-x-full");
    startScreen?.classList.remove("translate-x-full");
  });
</script>